{
  "dashboard": {
    "title": "Day 13 Observability Lab - Production Monitoring",
    "refresh_interval": "30s",
    "time_range": "1h",
    "panels": [
      {
        "id": 1,
        "title": "Latency Percentiles",
        "type": "time_series",
        "metrics": ["latency_p50", "latency_p95", "latency_p99"],
        "unit": "ms",
        "thresholds": [
          {
            "value": 3000,
            "color": "red",
            "label": "SLO P95 < 3000ms"
          }
        ],
        "position": {"x": 0, "y": 0, "w": 12, "h": 8}
      },
      {
        "id": 2,
        "title": "Request Traffic (QPS)",
        "type": "stat",
        "metrics": ["traffic"],
        "unit": "req/s",
        "calculation": "rate",
        "position": {"x": 12, "y": 0, "w": 6, "h": 8}
      },
      {
        "id": 3,
        "title": "Error Rate & Breakdown",
        "type": "time_series",
        "metrics": ["error_rate_pct", "error_breakdown"],
        "unit": "%",
        "thresholds": [
          {
            "value": 2,
            "color": "red",
            "label": "SLO Error Rate < 2%"
          }
        ],
        "position": {"x": 18, "y": 0, "w": 6, "h": 8}
      },
      {
        "id": 4,
        "title": "Cost Over Time",
        "type": "time_series",
        "metrics": ["total_cost_usd", "avg_cost_usd"],
        "unit": "USD",
        "thresholds": [
          {
            "value": 2.5,
            "color": "orange",
            "label": "Daily Budget $2.50"
          }
        ],
        "position": {"x": 0, "y": 8, "w": 12, "h": 8}
      },
      {
        "id": 5,
        "title": "Token Usage (In/Out)",
        "type": "time_series",
        "metrics": ["tokens_in_total", "tokens_out_total"],
        "unit": "tokens",
        "stacked": true,
        "position": {"x": 12, "y": 8, "w": 6, "h": 8}
      },
      {
        "id": 6,
        "title": "Hallucination %",
        "type": "gauge",
        "metrics": ["hallucination_pct"],
        "unit": "%",
        "min": 0,
        "max": 100,
        "thresholds": [
          {
            "value": 25,
            "color": "green",
            "label": "Target Hallucination < 25%"
          },
          {
            "value": 50,
            "color": "yellow"
          },
          {
            "value": 75,
            "color": "red"
          }
        ],
        "position": {"x": 18, "y": 8, "w": 6, "h": 8}
      }
    ]
  }
}